{
  "name": "gun-peer-server",
  "version": "1.0.0",
  "description": "Cloudflare Workers Gun.js-compatible peer with persistent Durable Object storage",
  "type": "module",
  "main": "src/worker.js",
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/logs CLOUDFLARE_TELEMETRY_DISABLED=1 wrangler dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/logs CLOUDFLARE_TELEMETRY_DISABLED=1 wrangler deploy --dry-run --outdir dist",
    "deploy": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy"
  },
  "keywords": [
    "gun",
    "peer",
    "server",
    "production"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "gun": "^0.2020.1241",
    "wrangler": "^4.16.1"
  }
}
