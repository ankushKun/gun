# Server Configuration
PORT=8765

# Peer Configuration (comma-separated list of peer URLs)
# PEERS=https://peer1.example.com/gun,https://peer2.example.com/gun

# Optional: require this bearer token for POST/DELETE on /api/peers (set via wrangler secret)
# PEERS_EDIT_TOKEN=your-secret-here

# E2E only: enables /api/e2e/* when wrangler dev is started with E2E_RESET_TOKEN set
# E2E_RESET_TOKEN=local-e2e-only

# Optional: storage eviction thresholds (defaults match worker: 9 GB trigger, 1 GB freed per pass)
STORAGE_EVICT_AT_BYTES=9663676416
STORAGE_EVICT_BYTES=1073741824

# Production Mode
NODE_ENV=production
